# Local service URLs
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
PREFECT_API_URL=http://127.0.0.1:4200/api

# Model registry defaults
MLFLOW_EXPERIMENT_NAME=flight-delay-prediction
MLFLOW_MODEL_NAME=flight-delay-prediction

# Optional model selection overrides
# Leave these blank on the first pass so the repo resolves the newest registered version
#MODEL_URI=
#MODEL_ALIAS=
#MODEL_STAGE=
#MODEL_VERSION=
#MODEL_RUN_ID=
#MODEL_ARTIFACT_PATH=model

# Dataset and output locations
# The datasets stay remote to keep this repo lightweight; only the services run locally
#TRAIN_DATA_URI=https://d37ci6vzurychx.cloudfront.net/trip-data/green_tripdata_2025-01.parquet
#BATCH_INPUT_URI=https://d37ci6vzurychx.cloudfront.net/trip-data/green_tripdata_2025-02.parquet
BATCH_OUTPUT_DIR=data/predictions

POSTGRES_USER=vikmar
POSTGRES_PASSWORD=vikmar


